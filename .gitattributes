# 强制 shell 脚本为 LF 行尾，避免在 Windows 上被打成 CRLF
# 导致 macOS/Linux 执行时 /bin/bash^M 错误
*.sh           text eol=lf
*.command      text eol=lf

# Windows 脚本保持 CRLF（PowerShell/cmd 对 CRLF 更友好）
*.ps1          text eol=crlf
*.cmd          text eol=crlf

# 油猴脚本/JS/Python/文档用 LF
*.js           text eol=lf
*.py           text eol=lf
*.md           text eol=lf
*.html         text eol=lf
*.json         text eol=lf
*.txt          text eol=lf
*.yaml         text eol=lf
*.yml          text eol=lf
*.toml         text eol=lf
*.ini          text eol=lf

# 二进制文件
*.png          binary
*.jpg          binary
*.jpeg         binary
*.gif          binary
*.zip          binary
*.pt           binary
*.safetensors  binary
*.onnx         binary
*.ico          binary
